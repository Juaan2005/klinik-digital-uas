{
  "expo": {
    "name": "Klinik Digital",
    "slug": "klinik-digital-uas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0EA5A4"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mahasiswa.klinikdigital"
    },
    "android": {
      "package": "com.mahasiswa.klinikdigital",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0EA5A4"
      },
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikasi membutuhkan akses galeri untuk foto KTP.",
          "cameraPermission": "Aplikasi membutuhkan akses kamera untuk foto KTP."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "GANTI-DENGAN-PROJECT-ID-EAS-KAMU"
      }
    }
  }
}